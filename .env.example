# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# Em produção use Neon (https://neon.tech) ou Supabase (https://supabase.com).
# Copie a connection string fornecida por eles aqui.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# Gere um segredo com: openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# URL pública da aplicação (em produção, a URL da Vercel)
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Integração com a landing page (focus-digital-site)
# Chave secreta que a landing envia no header x-api-key ao cadastrar um lead
# pelo endpoint público /api/leads/intake. Use a MESMA chave nos dois projetos.
# Gere com: openssl rand -base64 32
# ---------------------------------------------------------------------------
LEADS_API_KEY="troque-por-uma-chave-aleatoria"

# ---------------------------------------------------------------------------
# Integração com o Todoist (uma via: o CRM apenas exibe as tarefas)
# Pegue o token em: Todoist > Configurações > Integrações > Desenvolvedor.
# Sem este token, a aba Tarefas mostra uma mensagem de "não configurado".
# ---------------------------------------------------------------------------
TODOIST_API_TOKEN="seu-token-da-api-do-todoist"

# ---------------------------------------------------------------------------
# Integração com o Meta (Marketing API) — métricas de anúncios (somente leitura)
# Token de acesso (de usuário ou system user) com a permissão ads_read.
# Cada cliente guarda o ID da conta de anúncio (act_...) no cadastro.
# ---------------------------------------------------------------------------
META_ACCESS_TOKEN="seu-token-da-marketing-api-do-meta"
