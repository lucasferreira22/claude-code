# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# Em produção use Neon (https://neon.tech) ou Supabase (https://supabase.com).
# Copie a connection string fornecida por eles aqui.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# Gere um segredo com: openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# URL pública da aplicação (em produção, a URL da Vercel)
AUTH_URL="http://localhost:3000"
