// CRM Focus Digital — modelo de dados (Fase 1)
// Banco relacional PostgreSQL via Prisma.
// Ganchos para o módulo financeiro futuro já previstos (ver Client.valorMensal).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Usuários (você + colaboradores). Fase 1: todos têm o mesmo nível de acesso.
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senhaHash    String
  criadoEm     DateTime @default(now())

  // Clientes pelos quais este usuário é responsável interno
  clientesResponsavel Client[]              @relation("ResponsavelInterno")
  // Notas/registros de histórico criados por este usuário
  notas               ClientNote[]
  mudancasStatus      ClientStatusHistory[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Agências parceiras (clientes B2B que terceirizam a gestão de tráfego)
// ---------------------------------------------------------------------------
model PartnerAgency {
  id                 String   @id @default(cuid())
  nome               String
  contatoNome        String?
  contatoEmail       String?
  contatoTelefone    String?
  observacoes        String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  clientes Client[]

  @@map("partner_agencies")
}

enum TipoRelacao {
  DIRETO
  PARCERIA
}

enum ClientStatus {
  LEAD
  EM_NEGOCIACAO
  ATIVO
  PAUSADO
  ENCERRADO
}

// Categoria do cliente: separa recorrentes, pontuais e hospedagem na base.
enum Categoria {
  RECORRENTE
  PONTUAL
  HOSPEDAGEM
}

enum TipoContato {
  TELEFONE
  EMAIL
  WHATSAPP
}

// Situação da cobrança mensal de um cliente em uma competência (mês).
enum PaymentStatus {
  PENDENTE
  PAGO
}

// Cobrança avulsa: pontual (uma vez) ou recorrente.
enum TipoCobranca {
  PONTUAL
  RECORRENTE
}

// Periodicidade de uma cobrança avulsa recorrente.
enum Recorrencia {
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// ---------------------------------------------------------------------------
// Clientes — núcleo do sistema
// ---------------------------------------------------------------------------
model Client {
  id              String       @id @default(cuid())
  nomeRazaoSocial String
  cnpj            String?
  nicho           String?
  cidade          String?
  estado          String?

  tipoRelacao TipoRelacao
  // Preenchido apenas quando tipoRelacao = PARCERIA
  partnerAgency   PartnerAgency? @relation(fields: [partnerAgencyId], references: [id], onDelete: SetNull)
  partnerAgencyId String?

  // Responsável interno (colaborador da equipe)
  responsavel   User?   @relation("ResponsavelInterno", fields: [responsavelId], references: [id], onDelete: SetNull)
  responsavelId String?

  status            ClientStatus @default(LEAD)
  categoria         Categoria    @default(RECORRENTE)
  dataInicioContrato DateTime?
  dataFimContrato    DateTime?

  // Financeiro: valor mensal do contrato e custo mensal (para cálculo de lucro)
  valorMensal Decimal? @db.Decimal(12, 2)
  custoMensal Decimal? @db.Decimal(12, 2)

  // Cobrança recorrente: dia do mês em que o pagamento vence (1–31)
  diaVencimento Int?

  // Hospedagem/domínio (add-on, independente da categoria): se o cliente tem
  // hospedagem, próxima renovação e valor (cobrança anual).
  possuiHospedagem Boolean   @default(false)
  dataRenovacao    DateTime?
  valorRenovacao   Decimal?  @db.Decimal(12, 2)

  // Integração com o Meta (Marketing API): ID da conta de anúncio do cliente
  // (ex: "act_123456789"). Usado para puxar as métricas dos anúncios.
  metaAdAccountId String?

  observacoes String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  servicos        ClientService[]
  contatos        ClientContact[]
  notas           ClientNote[]
  statusHistory   ClientStatusHistory[]
  pagamentos      Payment[]
  cobrancasAvulsas CustomCharge[]

  @@index([tipoRelacao])
  @@index([status])
  @@index([categoria])
  @@index([nicho])
  @@index([responsavelId])
  @@map("clients")
}

// Cobrança mensal de um cliente. Uma linha por cliente por competência (mês).
model Payment {
  id           String        @id @default(cuid())
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  competencia  String        // "AAAA-MM" (ex: "2026-06")
  valor        Decimal       @db.Decimal(12, 2)
  status       PaymentStatus @default(PENDENTE)
  pagoEm       DateTime?
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  @@unique([clientId, competencia])
  @@index([competencia, status])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Cobranças avulsas — cada categoria vira uma "aba" criável em Financeiro
// (ex.: "Criação de Sites"), agrupando cobranças pontuais/recorrentes de
// vários clientes. Modelo espelha o de Cobranças mensais: a definição
// (CustomCharge) + status por competência (CustomChargePayment).
// ---------------------------------------------------------------------------

// Aba/categoria de cobrança avulsa, com nome personalizado pelo usuário.
model ChargeCategory {
  id           String         @id @default(cuid())
  nome         String
  ordem        Int            @default(0)
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  cobrancas CustomCharge[]

  @@map("charge_categories")
}

// Cobrança avulsa de um cliente dentro de uma categoria.
model CustomCharge {
  id                 String         @id @default(cuid())
  category           ChargeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId         String
  client             Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId           String
  descricao          String?
  valor              Decimal        @db.Decimal(12, 2)
  tipo               TipoCobranca   @default(RECORRENTE)
  // null quando tipo = PONTUAL
  recorrencia        Recorrencia?
  // Data-âncora: 1º vencimento (define o dia e, nas recorrentes, o ciclo)
  primeiroVencimento DateTime
  ativo              Boolean        @default(true)
  criadoEm           DateTime       @default(now())
  atualizadoEm       DateTime       @updatedAt

  pagamentos CustomChargePayment[]

  @@index([categoryId])
  @@index([clientId])
  @@map("custom_charges")
}

// Status de pagamento de uma cobrança avulsa numa competência (mês). Criado
// sob demanda quando a ocorrência do mês é marcada como paga.
model CustomChargePayment {
  id           String        @id @default(cuid())
  charge       CustomCharge  @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  chargeId     String
  competencia  String        // "AAAA-MM"
  status       PaymentStatus @default(PENDENTE)
  pagoEm       DateTime?
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  @@unique([chargeId, competencia])
  @@map("custom_charge_payments")
}

// Serviços contratados (N:N modelado como tabela de junção com enum)
model ClientService {
  id        String  @id @default(cuid())
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String

  @@unique([clientId, serviceId])
  @@map("client_services")
}

// Catálogo de serviços da agência (gerenciável pela tela /servicos).
// Pode ter hierarquia: uma categoria (ex: "Tráfego Pago") agrupa subserviços
// (Meta Ads, Google Ads...) via parentId.
model Service {
  id           String          @id @default(cuid())
  nome         String          @unique
  descricao    String?
  ativo        Boolean         @default(true)
  ordem        Int             @default(0)
  parent       Service?        @relation("ServiceTree", fields: [parentId], references: [id], onDelete: SetNull)
  parentId     String?
  filhos       Service[]       @relation("ServiceTree")
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  clientes     ClientService[]

  @@map("services")
}

// Contatos do cliente (telefone, e-mail, WhatsApp)
model ClientContact {
  id        String      @id @default(cuid())
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  tipo      TipoContato
  valor     String
  principal Boolean     @default(false)

  @@map("client_contacts")
}

// Linha do tempo de mudanças de status
model ClientStatusHistory {
  id             String        @id @default(cuid())
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  statusAnterior ClientStatus?
  statusNovo     ClientStatus
  alteradoPor    User?         @relation(fields: [alteradoPorId], references: [id], onDelete: SetNull)
  alteradoPorId  String?
  dataMudanca    DateTime      @default(now())

  @@index([clientId])
  @@map("client_status_history")
}

// Diário de interações datadas com o cliente
model ClientNote {
  id        String   @id @default(cuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  autor     User?    @relation(fields: [autorId], references: [id], onDelete: SetNull)
  autorId   String?
  conteudo  String
  criadoEm  DateTime @default(now())

  @@index([clientId])
  @@map("client_notes")
}
